# Example environment variables for MIDAS assistant
# Do NOT commit real secrets. Copy this file to .env and fill values.

MIDAS_API_URL=https://api.exemplo-midas.com/v1/chat
MIDAS_API_KEY=your_public_api_key_here

# Optional: override API proxy target used by server proxy
VITE_API_BASE_URL=

# Google Cloud APIs (Translate / Vision) - create API key in Google Cloud Console
GOOGLE_API_KEY=your_google_api_key_here
# Example environment variables for mobile app deployment
VITE_API_BASE_URL=https://seu-endpoint-api.azurewebsites.net
API_PROXY_TARGET=https://seu-endpoint-api.azurewebsites.net
PORT=3000
